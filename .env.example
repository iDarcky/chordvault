# Supabase project credentials — copy this file to .env.local and fill in.
# Get these from Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth Client IDs for cloud sync providers.
# These are public client IDs (not secrets) — safe to embed in the frontend bundle.
# Set these in Vercel dashboard for production, or copy to .env.local for development.
VITE_GOOGLE_CLIENT_ID=
VITE_DROPBOX_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
