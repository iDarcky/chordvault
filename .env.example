# Setlists.md environment variables
#
# Copy this file to `.env.local` for local dev (Vite reads it automatically).
# In production, configure the same keys as Project Environment Variables in
# Vercel. Anything prefixed with VITE_ is exposed to the browser bundle —
# only put values here that are safe to ship in client JavaScript.

# ─── Supabase (auth + account preferences) ────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API.
# When unset, the app degrades gracefully to a guest experience: auth UI
# disappears, profile sync is a no-op, and everything still works locally.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Sentry (optional, error tracking) ────────────────────────────────────
# Leave blank to disable. With a DSN set, errors are reported with the
# release tag from VITE_APP_VERSION. Both src/sentry.js and the dynamic
# @sentry/react import are guarded — missing DSN means no-op.
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# ─── Apple Sign-In (optional, default: off) ───────────────────────────────
# Apple Sign-In requires a paid Apple Developer account. Set to 'true' once
# you've configured Sign in with Apple in the Supabase dashboard.
VITE_ENABLE_APPLE_SIGNIN=false

# ─── OAuth Client IDs for cloud sync providers ────────────────────────────
# Public client IDs only (not secrets) — safe to embed in the frontend bundle.
# Set these in Vercel dashboard for production, or copy to .env.local for dev.
VITE_GOOGLE_CLIENT_ID=
VITE_DROPBOX_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
